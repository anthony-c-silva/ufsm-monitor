# Configuração do ufsm-monitor-agent (lida pelo systemd via EnvironmentFile).
# Copie para /etc/ufsm-monitor/agent.env e ajuste.

# Identidade permanente do probe.
# Se PROBE_ID for definido, tem prioridade sobre o arquivo de identidade.
# Caso contrário, o agente lê (ou gera e persiste) o id em PROBE_ID_FILE.
# PROBE_ID=probe-ct-01
PROBE_ID_FILE=/var/lib/ufsm-monitor/probe-id

# Banco local (outbox SQLite)
SQLITE_PATH=/var/lib/ufsm-monitor/agent.db

# Diretório-spool de tarefas locais (Fase 2, antes do RabbitMQ)
TASKS_DIR=/var/lib/ufsm-monitor/tasks

# Servidor HTTP de saúde (/health, /version, /metadata) e alvo de testes HTTP
HEALTH_ADDR=:8080

# Frequência da coleta de inventário (segundos)
INVENTORY_INTERVAL_SECONDS=60

# Rótulos de implantação (aparecem no inventário; opcionais)
DEPLOYMENT=CT-sala-101
VLAN=vlan-monitor
