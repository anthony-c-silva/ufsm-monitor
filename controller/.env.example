# Copie para .env e ajuste se necessário.
DATABASE_URL=postgresql+psycopg2://ufsm:ufsm@localhost:5432/monitor
AMQP_URL=amqp://guest:guest@localhost:5672/

# Limites de validação de planos
MIN_PERIOD_SECONDS=10
MAX_IPERF_DURATION=30
MAX_TASKS_PER_CYCLE=500

# Validade de cada tarefa publicada (segundos)
TASK_TTL_SECONDS=90
