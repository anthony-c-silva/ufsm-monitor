{
  "uid": "ufsm-overview",
  "title": "UFSM Monitor — Visão Geral",
  "tags": ["ufsm", "monitoramento"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "ICMP — RTT médio (ms) por destino",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "auto" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawSql": "SELECT observed_at AS \"time\", target AS metric, rtt_avg_ms FROM icmp_measurements WHERE $__timeFilter(observed_at) ORDER BY observed_at"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "ICMP — Perda (%) por destino",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawSql": "SELECT observed_at AS \"time\", target AS metric, loss_pct FROM icmp_measurements WHERE $__timeFilter(observed_at) ORDER BY observed_at"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP — TTFB e Tempo total (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawSql": "SELECT observed_at AS \"time\", ttfb_ms AS \"TTFB\", total_ms AS \"Total\" FROM http_measurements WHERE $__timeFilter(observed_at) ORDER BY observed_at"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "DNS — Tempo de resolução (ms) por nome",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "time_series",
          "rawSql": "SELECT observed_at AS \"time\", target AS metric, elapsed_ms FROM dns_measurements WHERE $__timeFilter(observed_at) ORDER BY observed_at"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Matriz Origem × Destino — ICMP (período selecionado)",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "postgres", "uid": "timescaledb" },
      "options": { "showHeader": true, "cellHeight": "sm" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "RTT médio (ms)" },
            "properties": [
              { "id": "unit", "value": "ms" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 80 } ] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Perda %" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 } ] } }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "postgres", "uid": "timescaledb" },
          "format": "table",
          "rawSql": "SELECT probe_id AS \"Origem\", target AS \"Destino\", round(avg(rtt_avg_ms)::numeric, 2) AS \"RTT médio (ms)\", round(avg(loss_pct)::numeric, 2) AS \"Perda %\", count(*) AS \"Amostras\" FROM icmp_measurements WHERE $__timeFilter(observed_at) GROUP BY probe_id, target ORDER BY 1, 2"
        }
      ]
    }
  ]
}
